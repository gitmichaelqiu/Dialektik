{
  "name": "dialektik-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/flutter-dev.mjs",
    "flutter:dev": "node scripts/flutter-dev.mjs",
    "flutter:web": "cd flutter_ui && flutter run -d chrome",
    "flutter:ios": "cd flutter_ui && flutter run -d ios",
    "flutter:analyze": "cd flutter_ui && flutter analyze",
    "build": "node scripts/flutter-build.mjs",
    "flutter:build:web": "cd flutter_ui && flutter build web",
    "flutter:build:ios": "cd flutter_ui && flutter build ios",
    "preview": "cd flutter_ui && flutter run -d chrome",
    "engine:build": "vite build --config vite.config.engine.ts"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "peerjs": "^1.5.5",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
