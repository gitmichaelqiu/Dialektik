{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "flutter:dev": "node scripts/flutter-dev.mjs",
    "flutter:web": "cd flutter_ui && flutter run -d chrome",
    "flutter:ios": "cd flutter_ui && flutter run -d ios",
    "flutter:analyze": "cd flutter_ui && flutter analyze",
    "build": "tsc && vite build",
    "flutter:build:web": "cd flutter_ui && flutter build web",
    "flutter:build:ios": "cd flutter_ui && flutter build ios",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run"
  },
  "dependencies": {
    "@mantine/core": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "dexie": "^4.4.4",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.468.0",
    "octokit": "^5.0.5",
    "peerjs": "^1.5.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.2",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "fake-indexeddb": "^6.2.5",
    "typescript": "~5.8.3",
